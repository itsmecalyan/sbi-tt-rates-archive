{
  "cleanUrls": true,
  "routes": [
    {
      "src": "/rates/(.*)",
      "headers": {
        "cache-control": "public, max-age=3600, s-maxage=3600"
      },
      "dest": "/rates/$1"
    },
    {
      "src": "/(202[0-9])/([0-9]{2})/(.*\\.pdf)",
      "dest": "https://raw.githubusercontent.com/itsmecalyan/sbi-tt-rates-archive/main/$1/$2/$3"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
